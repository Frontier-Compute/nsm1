        "construction": "BLAKE2b_32(0x02 || len(wallet_hash) || wallet_hash || len(serial_number) || serial_number)",
        "length_prefix": "2-byte big-endian",
        "input_fields": {"wallet_hash": "wallet_abc", "serial_number": "Z15P-2026-001"},
        "expected_hash": "5d77b9a3435948a98099267e510a14663cc0fa80afd2a3ee5fb4363f6ecdfa13"
      },
      {
        "id": "2.5",
        "event_type": "OWNERSHIP_ATTEST",
