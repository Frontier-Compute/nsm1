    "personalization_length": 13,
    "personalization_padded_to_16": "NordicShield_\\x00\\x00\\x00",
    "digest_size": 32,
    "vectors": [
      {
        "id": "2.1",
        "event_type": "PROGRAM_ENTRY",
        "type_byte": "0x01",
        "construction": "BLAKE2b_32(0x01 || wallet_hash)",
        "input_fields": {"wallet_hash": "wallet_abc"},
        "expected_hash": "344a05bf81faf6e2d54a0e52ea0267aff0244998eb1ee27adf5627413e92f089"
      },
      {
        "id": "2.2",
        "event_type": "PROGRAM_ENTRY",
        "type_byte": "0x01",
        "construction": "BLAKE2b_32(0x01 || wallet_hash)",
        "input_fields": {"wallet_hash": "e2e_wallet_20260327"},
        "expected_hash": "075b00df286038a7b3f6bb70054df61343e3481fba579591354a00214e9e019b"
      },
      {
        "id": "2.3",
        "event_type": "PROGRAM_ENTRY",
        "type_byte": "0x01",
        "construction": "BLAKE2b_32(0x01 || wallet_hash)",
