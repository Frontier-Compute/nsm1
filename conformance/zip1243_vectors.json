{
  "suite": "ZIP 1243 Conformance Vectors",
  "version": "1.0.0",
  "date": "2026-04-02",
  "description": "Published test vectors for ZIP 1243 (ZAP1 Structured Attestation Protocol). Each vector maps to a specific MUST/SHOULD requirement in the ZIP draft.",
  "leaf_hash_function": "BLAKE2b-256",
  "leaf_personalization": "NordicShield_",
  "leaf_personalization_padded_hex": "4e6f72646963536869656c645f000000",
  "node_hash_function": "BLAKE2b-256",
  "node_personalization": "NordicShield_MRK",
  "node_personalization_hex": "4e6f72646963536869656c645f4d524b",

  "section_1_memo_envelope": {
    "requirement": "Binary payload layout and memo encoding (ZIP 1243 Section: Binary Payload Layout)",
    "vectors": [
      {
        "id": "1.1",
        "description": "Type byte 0x01 is valid (PROGRAM_ENTRY)",
        "type_byte": 1,
        "valid": true
      },
      {
        "id": "1.2",
        "description": "Type byte 0x09 is valid (MERKLE_ROOT)",
        "type_byte": 9,
        "valid": true
      },
      {
        "id": "1.3",
        "description": "Type byte 0x0F is valid (GOVERNANCE_RESULT)",
        "type_byte": 15,
        "valid": true
      },
      {
        "id": "1.4",
        "description": "Type byte 0x00 is invalid (below range)",
        "type_byte": 0,
        "valid": false
      },
      {
        "id": "1.5",
        "description": "Type byte 0x46 is invalid (above defined range)",
        "type_byte": 70,
        "valid": false
      },
      {
        "id": "1.6",
        "description": "Memo wire format fits 512-byte memo field",
        "memo_string": "ZAP1:01:075b00df286038a7b3f6bb70054df61343e3481fba579591354a00214e9e019b",
        "byte_length": 72,
        "max_memo_bytes": 512,
        "fits": true
      },
      {
        "id": "1.7",
        "description": "Binary payload layout version byte",
        "version_byte": 1,
        "comment": "First byte of binary layout MUST be 0x01"
      },
      {
        "id": "1.8",
        "description": "Integers MUST be big-endian",
        "value": 2026,
        "big_endian_u32_hex": "000007ea"
      }
    ]
  },

  "section_2_hash_construction": {
